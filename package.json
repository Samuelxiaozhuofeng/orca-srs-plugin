{
  "name": "orca-srs",
  "version": "1.0.1",
  "private": true,
  "description": "虎鲸标记 — Orca Notes 内置间隔重复记忆（SRS）闪卡插件",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Samuelxiaozhuofeng/orca-srs-plugin.git"
  },
  "homepage": "https://github.com/Samuelxiaozhuofeng/orca-srs-plugin",
  "bugs": {
    "url": "https://github.com/Samuelxiaozhuofeng/orca-srs-plugin/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "cross-env NODE_ENV=production tsc && vite build",
    "test": "vitest run",
    "test:release": "node --test scripts/lib/deploy-target.test.mjs scripts/lib/release-gates.test.mjs scripts/release-verify.integration.test.mjs",
    "preview": "vite preview",
    "deploy:local": "node scripts/deploy-local.mjs",
    "release:licenses": "node scripts/release-licenses.mjs",
    "release:stage": "node scripts/release-stage.mjs",
    "release:verify": "node scripts/release-verify.mjs",
    "release:ready": "node scripts/release-ready.mjs",
    "release:zip": "node scripts/release-zip.mjs"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "valtio": "^1.13.2"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-v8": "^4.0.16",
    "cross-env": "^10.1.0",
    "fast-check": "^4.4.0",
    "jsdom": "^29.1.1",
    "rollup-plugin-external-globals": "^0.9.2",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jszip": "^3.10.1",
    "ts-fsrs": "^5.2.3"
  }
